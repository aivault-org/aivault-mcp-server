{
  "name": "aivault-mcp-server",
  "version": "2.0.0",
  "description": "MCP Server for AIVault — search, sync, and manage your AI conversations from any agent. Connects to your AIVault instance via HTTP API.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aivault-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "keywords": ["mcp", "aivault", "ai", "conversation", "knowledge-base", "rag", "agent"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  }
}
