{
  "name": "@aivault/aivault-mcp-server",
  "version": "0.1.7",
  "description": "MCP Server for AIVault — search, sync, and manage your AI conversations from any agent. Connects to your AIVault instance via HTTP API.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aivault-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aivault-org/aivault-mcp-server.git"
  },
  "homepage": "https://github.com/aivault-org/aivault-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/aivault-org/aivault-mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "aivault",
    "ai",
    "conversation",
    "knowledge-base",
    "rag",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "undici": "^8.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  }
}
